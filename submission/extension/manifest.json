{
  "manifest_version": 3,
  "name": "Kindle Bestseller Scraper",
  "version": "2.0",
  "description": "One-click extraction of Amazon Kindle bestsellers to CSV — with category switching, pagination, and scheduled scraping.",
  "permissions": ["activeTab", "scripting", "downloads", "storage", "alarms", "tabs"],
  "host_permissions": ["https://www.amazon.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icon.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.amazon.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "48": "icon.png"
  }
}
